# Enforce consistent LF line endings for text files
# Prevent accidental CRLF normalization commits on Windows

# Treat files as text and normalize to LF
* text=auto

# Explicitly set LF for common source and text file types
*.php     text eol=lf
*.phpt    text eol=lf
*.inc     text eol=lf
*.js      text eol=lf
*.css     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.xml     text eol=lf
*.html    text eol=lf
*.htm     text eol=lf
*.sh      text eol=lf
*.ps1     text eol=lf
*.py      text eol=lf
tests/**  text eol=lf
src/**    text eol=lf

# Binary files (do not attempt to normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.gz  binary
*.phar binary

# End of .gitattributes
