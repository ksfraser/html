#!/usr/bin/env php
<?php
// Cross-platform pre-commit hook (PHP-based).
// Place this file in .githooks and run: git config core.hooksPath .githooks

$root = realpath(__DIR__ . '/..');
if ($root === false) {
    fwrite(STDERR, "Could not determine repository root. Skipping @since checks.\n");
    exit(0);
}

$check = $root . DIRECTORY_SEPARATOR . 'scripts' . DIRECTORY_SEPARATOR . 'check-since.php';
if (!file_exists($check)) {
    fwrite(STDERR, "check-since.php not found at $check. Skipping @since checks.\n");
    exit(0);
}

$php = PHP_BINARY;
$cmd = escapeshellarg($php) . ' ' . escapeshellarg($check) . ' --staged --ci';
passthru($cmd, $exitCode);
if ($exitCode !== 0) {
    fwrite(STDERR, "Pre-commit hook failed: missing or malformed @since tags. Commit aborted.\n");
    exit($exitCode);
}

exit(0);
